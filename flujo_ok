<?php

namespace App\Console\Commands;

use Illuminate\Console\Command;
use Illuminate\Support\Facades\Mail;

class SendSubscriptionInfo extends Command
{
    protected $signature = 'subscription:send-info';
    protected $description = 'Send subscription information to users';

    public function __construct()
    {
        parent::__construct();
    }

    public function handle()
    {
        // Lógica para enviar correos a usuarios suscritos
        // Puedes usar un job para manejar esto en segundo plano
        $users = \App\Models\User::where('subscription_status', 'active')->get();

        foreach ($users as $user) {
            Mail::raw('Aquí está la información de su suscripción.', function ($message) use ($user) {
                $message->to($user->email)
                        ->subject('Información de suscripción');
            });
        }

        $this->info('Información de suscripción enviada.');
    }
}
Descripción: Tarea programada para enviar correos electrónicos a los usuarios suscritos.

